# ─── Dependencies ───────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ────────────────────────────────────
/.next/
/out/
/build
/dist/

# ─── Environment variables — NEVER commit these ──────────────
# Contains secrets: API keys, passwords, tokens
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
# Catch-all for any other .env variants
.env*.local

# ─── Testing ─────────────────────────────────────────────────
/coverage

# ─── OS / Editor files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem

# ─── Debug logs ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Vercel ──────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
