# ─────────────────────────────────────────────────────────────
# Raah India Experiences — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Nodemailer / Email Configuration ────────────────────────
#
# EMAIL_SERVICE:
#   The email provider. Use "gmail" for Gmail.
#   Other options: "yahoo", "hotmail", "smtp.sendgrid.net"
#   For custom SMTP, remove EMAIL_SERVICE and set EMAIL_HOST / EMAIL_PORT instead.
EMAIL_SERVICE=gmail

# EMAIL_USER:
#   The email address Nodemailer sends FROM.
#   For Gmail, this is your full Gmail address.
EMAIL_USER=kartikmaru2001@gmail.com

# EMAIL_PASS:
#   NOT your normal Gmail password.
#   For Gmail: go to myaccount.google.com → Security → 2-Step Verification → App Passwords
#   Generate an App Password for "Mail" → copy the 16-character code here.
#   Format: xxxx xxxx xxxx xxxx  (spaces are optional)
EMAIL_PASS=vwznefnaetqboana

# RECEIVER_EMAIL:
#   The inbox where booking enquiries land.
#   Can be the same as EMAIL_USER, or a different address you check regularly.
RECEIVER_EMAIL=kartikmaru2001@gmail.com

# ── Optional: Custom SMTP (use instead of EMAIL_SERVICE) ────
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=false   (true for port 465)
